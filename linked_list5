#include <iostream>    // deletion from beginning
using namespace std;
class Node {
    public:
    int data;
    Node* next;
    Node (int val) {
        data = val;
        next = nullptr;
    }
};
int main () {
    Node* head = new Node(100);
    head->next = new Node(200);
    head->next->next = new Node(300);
    head->next->next->next = new Node(400);
    head->next->next->next->next = new Node(500);

    cout << "Before deletion from beginning :\n";
    Node* temp = head;
    while(temp!=nullptr){
        cout << temp->data << " ";
        temp = temp->next;
    }
    
    temp = head;
    head = head->next;
    delete temp;

    cout << "\n";
    cout << "After deletion from beginning :\n";
    temp = head;
    while(temp!=nullptr){
        cout << temp->data << " ";
        temp = temp->next;
    }
    return 0;
}

