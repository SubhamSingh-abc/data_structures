#include <iostream>     // insertion in end
using namespace std;
class Node{
    public:
    int data;
    Node* next;
    Node(int val){
        data = val;
        next = nullptr;
    }
};
int main () {
    Node* head = new Node(100);
    head->next = new Node(200);
    head->next->next = new Node(300);
    head->next->next->next = new Node(400);

    Node* newNode = new Node(500);

    cout << "Before insertion in end :\n";
    Node* temp = head;
    while(temp!=nullptr){
        cout << temp->data << " ";
        temp = temp->next;
    }

    temp = head;
    while(temp->next!=nullptr){
        temp = temp->next;
    }
    temp->next = newNode;

    cout << "\n";
    cout << "After insertion in end :\n";
    Node* temp1 = head;
    while(temp1!=nullptr){
        cout << temp1->data << " ";
        temp1 = temp1->next;
    }
    return 0;
}

