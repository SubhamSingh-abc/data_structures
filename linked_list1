#include <iostream>       // single linked list
using namespace std;
class Node {
    public:
    int data;
    Node* next;
    Node (int val) {
        data = val;
        next = nullptr;
    } 
};
int main () {
    Node* head = new Node(10);
    head->next = new Node(20);
    head->next->next = new Node(30);

    cout << head->data << " ";
    cout << head->next->data << " ";
    cout << head->next->next->data << " ";

    Node* temp = head;
    Node* nextnode = nullptr;

    while(temp!=nullptr) {
        nextnode = temp->next;
        delete temp;
        temp = nextnode;
    }

    head = nullptr;

    return 0;
}
