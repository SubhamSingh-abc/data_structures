#include <iostream>        // insertion at any point
using namespace std;
class Node {
    public:
    int data;
    Node* next;
    Node(int val) {
        data = val;
        next = nullptr;
    }
};
    int main () {
    Node* head = new Node(100);
    head->next = new Node(200);
    head->next->next = new Node(400);
    head->next->next->next = new Node(500);

    cout << "Before insertion :\n";
    Node* temp1 = head;
    while(temp1!=nullptr){
        cout << temp1->data << " ";
        temp1 = temp1->next;
    }

    int val = 300;
    int position = 3;
    int count = 0;

    Node* temp = head;
    for(int i = 1 ; i < position - 1 ; i += 1){
        temp = temp->next;
        count += 1;
    }

    Node* newNode = new Node(val);
    newNode->next = temp->next;
    temp->next = newNode;

    cout << "\n";
    cout << "After insertion :\n";
    temp1 = head;
    while(temp1!=nullptr){
        cout << temp1->data << " ";
        temp1 = temp1->next;
    }

    temp1 = head;
    Node* nextNode = nullptr;
    while(temp1!=nullptr){
        nextNode = temp1->next;
        delete temp1;
        temp1 = nextNode;
    }

    head = nullptr;

    return 0;
}
